# Port to expose Rackpad on (default: 3000)
RACKPAD_PORT=3000

# Background health-check loop interval in milliseconds
MONITOR_INTERVAL_MS=300000

# GitHub user/org that owns the GHCR image (used by docker-compose.yml)
GITHUB_REPO_OWNER=kobii-git

# Image tag or release version to pull
RACKPAD_TAG=v0.9.3
